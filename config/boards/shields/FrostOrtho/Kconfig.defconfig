if SHIELD_FROSTORTHO_R

config ZMK_KEYBOARD_NAME
    default "FrostOrtho_R"

config ZMK_SPLIT
    default y


endif

if SHIELD_FROSTORTHO_L

config ZMK_KEYBOARD_NAME
    default "FrostOrtho_L"

config ZMK_SPLIT
    default y

endif

if SHIELD_FROSTORTHO_DONGLE

config ZMK_KEYBOARD_NAME
    default "FrostOrtho_dongle"

config ZMK_SPLIT
        default y

    config ZMK_SPLIT_ROLE_CENTRAL
        default y

    config ZMK_SPLIT_BLE_CENTRAL_PERIPHERALS
        default 2

endif